# ──────────────────────────────────────
#  Healthy Nanostore — .gitignore
# ──────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/
.env

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Results — keep code, exclude generated outputs
results/
*.png
*.pdf
*.svg
!docs/**/*.png
!docs/**/*.svg

# Logs and temp
*.log
.cache/
.pytest_cache/
.mypy_cache/

# Project-specific scratch
scratch/
tmp/
